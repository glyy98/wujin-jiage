/* addGoods/addGoods.wxss */
page {
  background-color: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  font-family: PingFang SC, sans-serif;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-item .input,
.form-item .picker {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
  line-height: 80rpx;
}

/* 所属大类 - 筛选框样式 */
.cat-filter-item .label {
  margin-bottom: 16rpx;
}

.cat-filter-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cat-filter-row .picker {
  flex: 1;
  min-width: 0;
}

.cat-filter-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f8f8;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.cat-filter-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cat-filter-text.placeholder {
  color: #999;
}

.cat-filter-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 22rpx;
  color: #999;
}

.cat-filter-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.link-manage {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #1a5fb4;
  padding: 0 12rpx;
}

.custom-cat {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.custom-cat-input {
  flex: 1;
  height: 72rpx !important;
  line-height: 72rpx !important;
  font-size: 26rpx !important;
}

.custom-cat-btn {
  flex-shrink: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

/* 供应商与规格 */
.supplier-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.supplier-section-head .label {
  margin-bottom: 0;
}

.supplier-blocks {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.supplier-block {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 1rpx solid #eee;
}

.supplier-block-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.supplier-block-head .picker {
  flex: 1;
  min-width: 0;
}

.supplier-filter-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.supplier-filter-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.supplier-filter-text.placeholder {
  color: #999;
}

.supplier-filter-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 22rpx;
  color: #999;
}

.supplier-filter-hint {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.supplier-new-row {
  margin-bottom: 20rpx;
}

.supplier-new-input {
  height: 72rpx !important;
  line-height: 72rpx !important;
  font-size: 26rpx !important;
  background: #fff !important;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
}

.supplier-block-del {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #e54545;
  padding: 0 16rpx;
}

.supplier-block .sku-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.label-inline {
  font-size: 26rpx;
  color: #666;
}

.btn-add-supplier {
  margin-top: 20rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #1a5fb4;
  border: 2rpx dashed #1a5fb4;
  border-radius: 12rpx;
}

.btn-add-sku {
  font-size: 26rpx;
  color: #1a5fb4;
  padding: 0 16rpx;
}

.sku-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.sku-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.06);
}

.sku-row .input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.sku-row .sku-spec {
  min-width: 120rpx;
}

.sku-row .sku-cost,
.sku-row .sku-sale {
  min-width: 140rpx;
  max-width: 180rpx;
}

.sku-del {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #e54545;
  padding: 0 16rpx;
}

.form-item .label-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  margin-bottom: 16rpx;
}

.image-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
  position: relative;
}

.image-item .thumb {
  width: 100%;
  height: 100%;
}

.image-item .thumb-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 32rpx;
}

.image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
}

.image-add .add-icon {
  font-size: 56rpx;
  color: #999;
}

.btn-wrap {
  margin-top: 48rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.save-btn[loading] {
  opacity: 0.8;
}
