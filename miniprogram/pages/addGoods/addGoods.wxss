/* addGoods/addGoods.wxss */
page {
  background-color: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  font-family: PingFang SC, sans-serif;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-item .input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.form-item .label-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  margin-bottom: 16rpx;
}

.image-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
  position: relative;
}

.image-item .thumb {
  width: 100%;
  height: 100%;
}

.image-item .thumb-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 32rpx;
}

.image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
}

.image-add .add-icon {
  font-size: 56rpx;
  color: #999;
}

.btn-wrap {
  margin-top: 48rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.save-btn[loading] {
  opacity: 0.8;
}
