<!--addGoods/addGoods.wxml - 新增五金商品-->
<view class="container">
  <view class="form-card">
    <view class="form-item">
      <text class="label">商品名称</text>
      <input
        class="input"
        placeholder="请输入商品名称"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>
    <view class="form-item">
      <text class="label">规格</text>
      <input
        class="input"
        placeholder="请输入规格"
        value="{{spec}}"
        bindinput="onSpecInput"
      />
    </view>
    <view class="form-item">
      <text class="label">供应商</text>
      <input
        class="input"
        placeholder="请输入供应商"
        value="{{supplier}}"
        bindinput="onSupplierInput"
      />
    </view>
    <view class="form-item">
      <text class="label">来货价</text>
      <input
        class="input"
        type="digit"
        placeholder="请输入来货价"
        value="{{costPrice}}"
        bindinput="onCostPriceInput"
      />
    </view>
    <view class="form-item">
      <text class="label">售价</text>
      <input
        class="input"
        type="digit"
        placeholder="请输入售价"
        value="{{salePrice}}"
        bindinput="onSalePriceInput"
      />
    </view>
    <view class="form-item">
      <text class="label">商品图片</text>
      <text class="label-tip">最多5张，单张小于3M</text>
      <view class="image-row">
        <view
          class="image-item"
          wx:for="{{imageList}}"
          wx:key="*this"
        >
          <image class="thumb" src="{{item}}" mode="aspectFill" />
          <view class="thumb-del" data-index="{{index}}" bindtap="onRemoveImage">×</view>
        </view>
        <view
          wx:if="{{imageList.length < 5}}"
          class="image-item image-add"
          bindtap="onChooseImage"
        >
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
    <view class="btn-wrap">
      <button class="save-btn" type="primary" bindtap="onSave" loading="{{saving}}">保存</button>
    </view>
  </view>
</view>
