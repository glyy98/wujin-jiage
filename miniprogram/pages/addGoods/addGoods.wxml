<!--addGoods/addGoods.wxml - 新增五金商品-->
<view class="container">
  <view class="form-card">
    <view class="form-item cat-filter-item">
      <text class="label">所属大类</text>
      <view class="cat-filter-row">
        <picker mode="selector" range="{{categoryList}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
          <view class="cat-filter-box">
            <text class="cat-filter-text">{{categoryList.length && categoryList[categoryIndex] ? categoryList[categoryIndex].name : ''}}</text>
            <text class="cat-filter-arrow">▼</text>
          </view>
        </picker>
        <navigator class="link-manage" url="/pages/categoryManage/categoryManage">管理分类</navigator>
        <view class="link-add-cat" bindtap="openAddCategoryModal">新增大类</view>
      </view>
    </view>
    <view class="form-item cat-filter-item">
      <text class="label">所属二级分类</text>
      <view class="cat-filter-row">
        <picker mode="selector" range="{{subCategoryList}}" range-key="name" value="{{subCategoryIndex}}" bindchange="onSubCategoryChange">
          <view class="cat-filter-box">
            <text class="cat-filter-text">{{subCategoryList.length && subCategoryList[subCategoryIndex] ? subCategoryList[subCategoryIndex].name : '全部（可不选）'}}</text>
            <text class="cat-filter-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="form-item">
      <text class="label">商品名称</text>
      <input
        class="input"
        placeholder="请输入商品名称"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>
    <view class="form-item supplier-section">
      <view class="supplier-section-head">
        <text class="label">供应商与规格</text>
        <navigator class="link-manage" url="/pages/supplierManage/supplierManage">管理供应商</navigator>
      </view>
      <view class="sku-image-switch-row">
        <view class="sku-image-switch-text">
          <text class="sku-image-switch-label">规格单独配图</text>
          <text class="sku-image-switch-desc">{{useSkuImages ? '已开启：每个规格可上传不同图片' : '未开启：使用商品图片（全部规格共用）'}}</text>
        </view>
        <switch color="#1a5fb4" checked="{{useSkuImages}}" bindchange="onToggleSkuImageMode" />
      </view>
      <view class="supplier-blocks">
        <view class="supplier-block" wx:for="{{supplierList}}" wx:for-index="supplierIndex" wx:key="supplierIndex">
          <view class="supplier-block-head">
            <picker
              mode="selector"
              range="{{supplierOptions}}"
              value="{{item.supplierOptionIndex >= 0 && item.supplierOptionIndex < supplierOptions.length ? item.supplierOptionIndex : 0}}"
              data-supplier-index="{{supplierIndex}}"
              bindchange="onSupplierPickerChange"
            >
              <view class="supplier-filter-box">
                <text class="supplier-filter-text {{item.supplierName ? '' : 'placeholder'}}">{{item.supplierName || '请选择供应商'}}</text>
                <text class="supplier-filter-arrow">▼</text>
              </view>
            </picker>
            <view
              class="supplier-block-del"
              data-supplier-index="{{supplierIndex}}"
              bindtap="onRemoveSupplier"
              wx:if="{{supplierList.length > 1}}"
            >删除</view>
          </view>
          <view class="sku-head">
            <text class="label-inline">规格明细</text>
            <view class="btn-add-sku" data-supplier-index="{{supplierIndex}}" bindtap="onAddSku">+ 添加规格</view>
          </view>
          <view class="sku-drag-tip">点击移动可以修改当前规格排序</view>
          <view class="sku-list">
            <view class="sku-item" wx:for="{{item.skuList}}" wx:for-item="sku" wx:key="index">
              <view class="sku-row">
                <text class="sku-order-tag">{{index + 1}}.</text>
                <input
                  class="input sku-spec"
                  placeholder="规格名"
                  value="{{sku.specName}}"
                  data-supplier-index="{{supplierIndex}}"
                  data-sku-index="{{index}}"
                  bindinput="onSkuSpecInput"
                />
                <input
                  class="input sku-cost"
                  type="digit"
                  placeholder="来货价"
                  maxlength="6"
                  value="{{sku.costPrice}}"
                  data-supplier-index="{{supplierIndex}}"
                  data-sku-index="{{index}}"
                  bindinput="onSkuCostInput"
                />
                <input
                  class="input sku-sale"
                  type="digit"
                  placeholder="售价"
                  maxlength="6"
                  value="{{sku.salePrice}}"
                  data-supplier-index="{{supplierIndex}}"
                  data-sku-index="{{index}}"
                  bindinput="onSkuSaleInput"
                />
                <view
                  class="sku-move"
                  data-supplier-index="{{supplierIndex}}"
                  data-sku-index="{{index}}"
                  bindtap="onMoveSku"
                  wx:if="{{item.skuList.length > 1}}"
                >移动</view>
                <view
                  class="sku-del"
                  data-supplier-index="{{supplierIndex}}"
                  data-sku-index="{{index}}"
                  bindtap="onRemoveSku"
                  wx:if="{{item.skuList.length > 1}}"
                >删除</view>
              </view>
              <view class="sku-image-row" wx:if="{{useSkuImages}}">
                <view class="sku-image-box" data-supplier-index="{{supplierIndex}}" data-sku-index="{{index}}" bindtap="onChooseSkuImage">
                  <image wx:if="{{sku.image}}" class="sku-thumb" src="{{sku.image}}" mode="aspectFit" data-supplier-index="{{supplierIndex}}" data-sku-index="{{index}}" catchtap="onPreviewSkuImage" />
                  <text wx:else class="sku-image-add">+ 规格图</text>
                </view>
                <view class="sku-image-del" wx:if="{{sku.image}}" data-supplier-index="{{supplierIndex}}" data-sku-index="{{index}}" bindtap="onRemoveSkuImage">删除规格图</view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="btn-add-supplier" bindtap="onAddSupplier">+ 添加供应商</view>
    </view>
    <view class="form-item" wx:if="{{!useSkuImages}}">
      <text class="label">商品图片（所有规格都用这些图）</text>
      <text class="label-tip">最多5张，单张小于3M</text>
      <view class="image-row">
        <view
          class="image-item"
          wx:for="{{imageList}}"
          wx:key="*this"
        >
          <image class="thumb" src="{{item}}" mode="aspectFit" data-index="{{index}}" bindtap="onPreviewImage" />
          <view class="thumb-del" data-index="{{index}}" bindtap="onRemoveImage">×</view>
        </view>
        <view
          wx:if="{{imageList.length < 5}}"
          class="image-item image-add"
          bindtap="onChooseImage"
        >
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
    <view class="btn-wrap">
      <button class="save-btn" type="primary" bindtap="onSave" loading="{{saving}}">保存</button>
    </view>
  </view>
  <view class="add-cat-modal-mask" wx:if="{{showAddCategoryModal}}" catchtap="closeAddCategoryModal"></view>
  <view class="add-cat-modal-wrap" wx:if="{{showAddCategoryModal}}">
    <view class="add-cat-modal-box">
      <view class="add-cat-modal-close" bindtap="closeAddCategoryModal">×</view>
      <view class="add-cat-modal-title">新增大类</view>
      <input
        class="add-cat-modal-input"
        placeholder="请输入大类名称"
        value="{{newCategoryName}}"
        bindinput="onNewCategoryInput"
        focus="{{showAddCategoryModal}}"
      />
      <button class="add-cat-modal-btn" type="primary" bindtap="onAddCategory" loading="{{addingCategory}}">添加并选用</button>
    </view>
  </view>
</view>
