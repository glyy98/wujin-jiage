<!--addGoods/addGoods.wxml - 新增五金商品-->
<view class="container">
  <view class="form-card">
    <view class="form-item cat-filter-item">
      <text class="label">所属大类</text>
      <view class="cat-filter-row">
        <view class="cat-filter-picker-wrap">
          <view class="cat-filter-box" bindtap="onOpenCategoryModal" hover-class="cat-filter-hover" hover-stay-time="100">
            <text class="cat-filter-text {{categoryList.length && categoryList[categoryIndex] ? '' : 'placeholder'}}">{{categoryList.length && categoryList[categoryIndex] ? categoryList[categoryIndex].name : '请选择分类'}}</text>
            <text class="cat-filter-arrow">▼</text>
          </view>
        </view>
        <navigator class="link-manage" url="/pages/categoryManage/categoryManage">管理分类</navigator>
      </view>
      <view class="cat-filter-hint">请选择分类</view>
      <view class="custom-cat">
        <input
          class="input custom-cat-input"
          placeholder="没有合适的大类？输入新大类名称"
          value="{{newCategoryName}}"
          bindinput="onNewCategoryInput"
        />
        <button class="custom-cat-btn" size="mini" type="default" bindtap="onAddCategory" disabled="{{addingCategory}}">添加并选用</button>
      </view>
      <text class="label sub-cat-label">二级分类（选填）</text>
      <view class="cat-filter-sub-wrap">
        <view class="cat-filter-box" bindtap="onOpenSubCategoryModal" hover-class="cat-filter-hover" hover-stay-time="100">
          <text class="cat-filter-text {{subCategoryPickerRange.length > 1 ? '' : 'placeholder'}}">{{subCategoryPickerRange[subCategoryIndex] ? subCategoryPickerRange[subCategoryIndex].name : '无二级'}}</text>
          <text class="cat-filter-arrow">▼</text>
        </view>
      </view>
      <view class="cat-filter-hint">先选大类；无子分类时选「无二级（仅大类）」</view>
      <view class="custom-cat custom-sub-cat">
        <input
          class="input custom-cat-input"
          placeholder="没有合适的二级？输入新名称"
          value="{{newSubCategoryName}}"
          bindinput="onNewSubCategoryInput"
        />
        <button class="custom-cat-btn" size="mini" type="default" bindtap="onAddSubCategory" disabled="{{addingSubCategory}}">添加并选用</button>
      </view>
    </view>
    <view class="form-item">
      <text class="label">商品名称</text>
      <input
        class="input"
        placeholder="请输入商品名称"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>
    <view class="form-item supplier-section">
      <view class="supplier-section-head">
        <text class="label">供应商与规格</text>
        <navigator class="link-manage" url="/pages/supplierManage/supplierManage">管理供应商</navigator>
      </view>
      <view class="supplier-blocks">
        <view class="supplier-block" wx:for="{{supplierList}}" wx:for-index="supplierIndex" wx:key="supplierIndex">
          <view class="supplier-block-head">
            <view class="supplier-picker-wrap">
              <view
                class="supplier-filter-box"
                data-supplier-index="{{supplierIndex}}"
                bindtap="onOpenSupplierModal"
                hover-class="cat-filter-hover"
                hover-stay-time="100"
              >
                <text class="supplier-filter-text {{item.supplierName ? '' : 'placeholder'}}">{{item.supplierName || '请选择供应商'}}</text>
                <text class="supplier-filter-arrow">▼</text>
              </view>
            </view>
            <view
              class="supplier-block-del"
              data-supplier-index="{{supplierIndex}}"
              bindtap="onRemoveSupplier"
              wx:if="{{supplierList.length > 1}}"
            >删除</view>
          </view>
          <view class="sku-head">
            <text class="label-inline">规格明细</text>
            <view class="btn-add-sku" data-supplier-index="{{supplierIndex}}" bindtap="onAddSku">+ 添加规格</view>
          </view>
          <view class="sku-list">
            <view class="sku-row" wx:for="{{item.skuList}}" wx:for-item="sku" wx:key="index">
              <input
                class="input sku-spec"
                placeholder="规格名"
                value="{{sku.specName}}"
                data-supplier-index="{{supplierIndex}}"
                data-sku-index="{{index}}"
                bindinput="onSkuSpecInput"
              />
              <input
                class="input sku-cost"
                type="digit"
                placeholder="来货价"
                value="{{sku.costPrice}}"
                data-supplier-index="{{supplierIndex}}"
                data-sku-index="{{index}}"
                bindinput="onSkuCostInput"
              />
              <input
                class="input sku-sale"
                type="digit"
                placeholder="售价"
                value="{{sku.salePrice}}"
                data-supplier-index="{{supplierIndex}}"
                data-sku-index="{{index}}"
                bindinput="onSkuSaleInput"
              />
              <view
                class="sku-del"
                data-supplier-index="{{supplierIndex}}"
                data-sku-index="{{index}}"
                bindtap="onRemoveSku"
                wx:if="{{item.skuList.length > 1}}"
              >删除</view>
            </view>
          </view>
        </view>
      </view>
      <view class="btn-add-supplier" bindtap="onAddSupplier">+ 添加供应商</view>
    </view>
    <view class="form-item">
      <text class="label">商品图片</text>
      <text class="label-tip">最多5张，单张小于3M</text>
      <view class="image-row">
        <view
          class="image-item"
          wx:for="{{imageList}}"
          wx:key="*this"
        >
          <image class="thumb" src="{{item}}" mode="aspectFill" />
          <view class="thumb-del" data-index="{{index}}" bindtap="onRemoveImage">×</view>
        </view>
        <view
          wx:if="{{imageList.length < 5}}"
          class="image-item image-add"
          bindtap="onChooseImage"
        >
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
    <view class="btn-wrap">
      <button class="save-btn" type="primary" bindtap="onSave" loading="{{saving}}">保存</button>
    </view>
  </view>

  <!-- 所属大类：底部弹层列表（替代原生 picker，避免点击无反应） -->
  <view class="cat-select-mask" wx:if="{{showCategoryModal}}" catchtap="closeCategoryModal" catchtouchmove="preventTouchMove"></view>
  <view class="cat-select-sheet" wx:if="{{showCategoryModal}}">
    <view class="cat-select-title">选择大类</view>
    <scroll-view scroll-y class="cat-select-scroll">
      <view
        class="cat-select-item"
        wx:for="{{categoryList}}"
        wx:key="_id"
        data-index="{{index}}"
        bindtap="onSelectCategoryFromModal"
      >{{item.name}}</view>
    </scroll-view>
    <view class="cat-select-cancel" bindtap="closeCategoryModal">取消</view>
  </view>

  <!-- 二级分类：底部弹层 -->
  <view class="cat-select-mask" wx:if="{{showSubCategoryModal}}" catchtap="closeSubCategoryModal" catchtouchmove="preventTouchMove"></view>
  <view class="cat-select-sheet" wx:if="{{showSubCategoryModal}}">
    <view class="cat-select-title">二级分类（选填）</view>
    <scroll-view scroll-y class="cat-select-scroll">
      <view
        class="cat-select-item"
        wx:for="{{subCategoryPickerRange}}"
        wx:for-index="subIdx"
        wx:key="name"
        data-index="{{subIdx}}"
        bindtap="onSelectSubCategoryFromModal"
      >{{item.name}}</view>
    </scroll-view>
    <view class="cat-select-cancel" bindtap="closeSubCategoryModal">取消</view>
  </view>

  <!-- 供应商：底部弹层 -->
  <view class="cat-select-mask" wx:if="{{showSupplierModal}}" catchtap="closeSupplierModal" catchtouchmove="preventTouchMove"></view>
  <view class="cat-select-sheet" wx:if="{{showSupplierModal}}">
    <view class="cat-select-title">选择供应商</view>
    <scroll-view scroll-y class="cat-select-scroll">
      <view
        class="cat-select-item"
        wx:for="{{supplierOptions}}"
        wx:for-index="optIdx"
        wx:key="*this"
        data-index="{{optIdx}}"
        bindtap="onSelectSupplierFromModal"
      >{{item}}</view>
    </scroll-view>
    <view class="cat-select-cancel" bindtap="closeSupplierModal">取消</view>
  </view>
</view>
