<view class="container">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索供应商名称"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
    />
    <view class="search-btn" bindtap="onSearch">搜索</view>
    <view class="btn-add" bindtap="onAdd">新增供应商</view>
  </view>
  <view class="tip">此处仅管理「已保存的供应商」列表，删除后不影响已保存商品中的供应商名称；新增商品时仍可输入新供应商。</view>
  <view class="list" wx:if="{{filteredList.length > 0}}">
    <view class="item" wx:for="{{filteredList}}" wx:key="_id">
      <view class="item-body">
        <view class="item-label">供应商名称</view>
        <view class="name">{{item.name}}</view>
      </view>
      <view class="item-actions">
        <button
          class="btn-del"
          size="mini"
          data-id="{{item._id}}"
          data-name="{{item.name}}"
          bindtap="onDelete"
          loading="{{deletingId === item._id}}"
          disabled="{{deletingId !== null}}"
        >删除</button>
      </view>
    </view>
  </view>
  <view class="empty" wx:elif="{{!loading}}">
    <text>{{keyword ? "未找到匹配的供应商" : "暂无已保存的供应商，可在新增商品时输入并保存"}}</text>
  </view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <!-- 新增供应商弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" catchtap="closeAddModal"></view>
  <view class="modal-wrap" wx:if="{{showAddModal}}">
    <view class="modal-box">
      <view class="modal-title">新增供应商</view>
      <input
        class="modal-input"
        placeholder="请输入供应商名称"
        value="{{addName}}"
        bindinput="onAddNameInput"
        focus="{{showAddModal}}"
      />
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closeAddModal">取消</view>
        <view class="modal-btn confirm" bindtap="submitAdd">确定</view>
      </view>
    </view>
  </view>
</view>
