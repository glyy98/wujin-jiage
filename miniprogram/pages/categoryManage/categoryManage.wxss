page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  font-family: PingFang SC, sans-serif;
  box-sizing: border-box;
}

.search-bar {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a5fb4;
  font-weight: 500;
}

.tip {
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #666;
  padding: 20rpx 24rpx;
  background: #fff8e6;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 28rpx 28rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  box-sizing: border-box;
}

.item-body {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.item-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-edit {
  color: #1a5fb4;
  font-size: 28rpx;
  border: 1rpx solid #1a5fb4;
  background: #fff;
  line-height: 1.4;
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
}

.btn-edit[disabled] {
  opacity: 0.6;
}

.btn-del {
  color: #e54545;
  font-size: 28rpx;
  border: 1rpx solid #e54545;
  background: #fff;
  line-height: 1.4;
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
}

.btn-del[disabled] {
  opacity: 0.6;
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-wrap {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 101;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.modal-box {
  width: 100%;
  max-width: 560rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.modal-btn.confirm {
  background: #1a5fb4;
  color: #fff;
}

.empty,
.loading {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

.loading {
  color: #1a5fb4;
}
