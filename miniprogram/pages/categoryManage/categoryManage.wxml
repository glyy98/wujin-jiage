<view class="container">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索分类名称"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
    />
    <view class="search-btn" bindtap="onSearch">搜索</view>
    <view class="btn-add" bindtap="onAdd">新增分类</view>
  </view>
  <view class="tip">删除后，该分类下的商品会变为「未分类」，仅在首页「全部」中显示。</view>
  <view class="list" wx:if="{{filteredTree.length > 0}}">
    <view class="item" wx:for="{{filteredTree}}" wx:key="_id" wx:for-index="parentIndex">
      <view class="item-head">
        <view class="item-body">
          <view class="name">{{parentIndex + 1}}. {{item.name}}</view>
        </view>
        <view class="item-actions">
          <button class="btn-sort" size="mini" data-id="{{item._id}}" data-order="{{parentIndex + 1}}" data-total="{{filteredTree.length}}" bindtap="onMove" loading="{{movingId === item._id}}" disabled="{{deletingId !== null || movingId !== null}}">移动</button>
          <button class="btn-edit" size="mini" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onEdit" disabled="{{deletingId !== null || movingId !== null}}">编辑</button>
          <button class="btn-del" size="mini" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onDelete" loading="{{deletingId === item._id}}" disabled="{{deletingId !== null || movingId !== null}}">删除</button>
        </view>
      </view>
      <view class="add-child-btn" data-parent-id="{{item._id}}" data-parent-name="{{item.name}}" bindtap="onAddChild">+ 新增二级分类</view>
      <view class="child-list" wx:if="{{item.children && item.children.length}}">
        <view class="child-item" wx:for="{{item.children}}" wx:for-item="child" wx:key="_id" wx:for-index="childIndex">
          <view class="child-name">{{childIndex + 1}}. {{child.name}}</view>
          <view class="item-actions">
            <button class="btn-sort" size="mini" data-id="{{child._id}}" data-order="{{childIndex + 1}}" data-total="{{item.children.length}}" bindtap="onMove" loading="{{movingId === child._id}}" disabled="{{deletingId !== null || movingId !== null}}">移动</button>
            <button class="btn-edit" size="mini" data-id="{{child._id}}" data-name="{{child.name}}" bindtap="onEdit" disabled="{{deletingId !== null || movingId !== null}}">编辑</button>
            <button class="btn-del" size="mini" data-id="{{child._id}}" data-name="{{child.name}}" bindtap="onDelete" loading="{{deletingId === child._id}}" disabled="{{deletingId !== null || movingId !== null}}">删除</button>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="empty" wx:elif="{{!loading}}">
    <text>{{keyword ? "未找到匹配的分类" : "暂无分类，点击上方「新增分类」添加"}}</text>
  </view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <!-- 编辑分类弹窗 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" catchtap="closeEditModal"></view>
  <view class="modal-wrap" wx:if="{{showEditModal}}">
    <view class="modal-box">
      <view class="modal-title">编辑分类</view>
      <input
        class="modal-input"
        placeholder="请输入分类名称"
        value="{{editName}}"
        bindinput="onEditNameInput"
        focus="{{showEditModal}}"
      />
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closeEditModal">取消</view>
        <view class="modal-btn confirm" bindtap="submitEdit">确定</view>
      </view>
    </view>
  </view>

  <!-- 新增分类弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" catchtap="closeAddModal"></view>
  <view class="modal-wrap" wx:if="{{showAddModal}}">
    <view class="modal-box">
      <view class="modal-title">{{addParentId ? '新增二级分类' : '新增分类'}}</view>
      <view class="modal-subtitle" wx:if="{{addParentId}}">所属大类：{{addParentName}}</view>
      <input
        class="modal-input"
        placeholder="{{addParentId ? '请输入二级分类名称' : '请输入分类名称'}}"
        value="{{addName}}"
        bindinput="onAddNameInput"
        focus="{{showAddModal}}"
      />
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closeAddModal">取消</view>
        <view class="modal-btn confirm" bindtap="submitAdd">确定</view>
      </view>
    </view>
  </view>
</view>
