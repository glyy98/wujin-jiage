<!--index.wxml - 左侧大类树 + 右侧商品明细-->
<view class="container">
  <view class="header">
    <view class="page-title">金广业商品价格查询</view>
    <view class="action-bar">
      <button class="action-btn primary" size="mini" bindtap="goAddGoods">新增商品</button>
      <button class="action-btn" size="mini" bindtap="goGoodsList">商品列表</button>
      <button class="action-btn" size="mini" bindtap="goCategoryManage">分类管理</button>
    </view>
  </view>

  <view class="main">
    <!-- 左侧：大类树 -->
    <scroll-view class="sidebar" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        class="cat-item {{selectedCategoryId === item.id ? 'active' : ''}}"
        wx:for="{{categoryList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onSelectCategory"
      >
        <text class="cat-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧：该大类下的商品明细 -->
    <view class="content">
      <view class="search-bar">
        <input
          class="search-input"
          placeholder="在当前分类下搜索名称/规格"
          value="{{keyword}}"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
        />
        <view class="search-btn" bindtap="onSearch">搜索</view>
      </view>

      <scroll-view wx:if="{{selectedCategoryId && subNavList.length > 0}}" class="sub-nav-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="sub-nav-inner">
          <view
            class="sub-chip {{selectedSubCategoryId === item.id ? 'active' : ''}}"
            wx:for="{{subNavList}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onSelectSubCategory"
          >{{item.name}}</view>
        </view>
      </scroll-view>

      <scroll-view class="product-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="product-scroll-inner">
          <view class="product-list" wx:if="{{productList.length > 0}}">
            <view
              class="product-item"
              wx:for="{{productList}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="goDetail"
            >
              <view class="product-cover">
                <image
                  wx:if="{{item.image}}"
                  class="product-img"
                  src="{{item.image}}"
                  mode="aspectFill"
                />
                <view wx:else class="product-img product-img-placeholder">暂无图片</view>
              </view>
              <view class="product-info">
                <view class="product-name">{{item.name}}</view>
                <view class="product-spec" wx:if="{{item.spec}}">规格：{{item.spec}}</view>
                <view class="product-supplier" wx:if="{{item.supplier}}">供应商：{{item.supplier}}</view>
                <view class="product-prices">
                  <text class="price-label">售价</text>
                  <text class="price-sale">¥{{item.salePrice}}</text>
                  <text class="price-cost">来货价 ¥{{item.costPrice}}</text>
                </view>
              </view>
              <image class="arrow" src="../../images/arrow.svg" mode="aspectFit" />
            </view>
          </view>

          <view class="empty" wx:elif="{{!loading}}">
            <view class="empty-text">{{keyword ? "未找到相关商品" : (selectedCategoryId ? "该分类下暂无商品" : "暂无商品数据")}}</view>
          </view>
          <view class="loading" wx:if="{{loading}}">加载中...</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
