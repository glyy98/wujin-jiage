/* index.wxss - 五金店商品查询 */
page {
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.container {
  min-height: 100vh;
  font-family: PingFang SC, sans-serif;
}

.header {
  background: linear-gradient(135deg, #1a5fb4 0%, #3584e4 100%);
  padding: 32rpx 30rpx 40rpx;
  color: #fff;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a5fb4;
  font-weight: 500;
}

.action-bar {
  margin-top: 20rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.action-btn.primary {
  background-color: #ffffff;
  color: #1a5fb4;
}

.product-list {
  padding: 24rpx 24rpx 0;
}

.product-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-cover {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
}

.product-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-spec,
.product-supplier {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-prices {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.price-label {
  color: #999;
  margin-right: 8rpx;
}

.price-sale {
  color: #e54545;
  font-weight: 600;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.price-cost {
  color: #999;
  font-size: 22rpx;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: 16rpx;
  transform: rotate(90deg);
}

.empty,
.loading {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.loading {
  color: #1a5fb4;
}
