/* index.wxss - 左侧大类树 + 右侧商品明细 */
page {
  background-color: #f5f5f5;
  height: 100%;
}

.container {
  height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  font-family: PingFang SC, sans-serif;
  box-sizing: border-box;
}

.header {
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(135deg, #1a5fb4 0%, #3584e4 100%);
  padding: 24rpx 24rpx 28rpx;
  color: #fff;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.action-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.action-btn.primary {
  background-color: #ffffff;
  color: #1a5fb4;
}

/* 主体：左树右内容 */
.main {
  flex: 1;
  min-height: 0;
  min-width: 0;
  width: 100%;
  display: flex;
  background: #f5f5f5;
  box-sizing: border-box;
}

/* 左侧大类树 */
.sidebar {
  width: 176rpx;
  flex-shrink: 0;
  background: #fff;
  border-right: 1rpx solid #eee;
}

.cat-item {
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
  border-left: 4rpx solid transparent;
}

.cat-item.active {
  background: #e8f2fe;
  color: #1a5fb4;
  font-weight: 500;
  border-left-color: #1a5fb4;
}

.cat-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 右侧商品明细区 */
.content {
  flex: 1;
  min-width: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  box-sizing: border-box;
}

.search-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  background: #fff;
  margin: 24rpx 24rpx 0;
  padding: 0 20rpx;
  height: 72rpx;
  border-radius: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #333;
}

.search-btn {
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1a5fb4;
  font-weight: 500;
}

.product-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}

/* 撑满滚动内容宽度，无商品时左侧白条不往里缩 */
.product-scroll-inner {
  width: 100%;
  min-width: 100%;
  box-sizing: border-box;
}

.product-list {
  padding: 20rpx 24rpx 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.product-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-cover {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
}

.product-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-spec,
.product-supplier {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-prices {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.price-label {
  color: #999;
  margin-right: 8rpx;
}

.price-sale {
  color: #e54545;
  font-weight: 600;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.price-cost {
  color: #999;
  font-size: 22rpx;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: 16rpx;
  transform: rotate(90deg);
}

.empty,
.loading {
  padding: 80rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.loading {
  color: #1a5fb4;
}
