<!--product-detail/index.wxml - 商品详情-->
<view class="container" wx:if="{{product}}">
  <view class="cover-wrap">
    <swiper
      wx:if="{{product.images && product.images.length > 0}}"
      class="cover-swiper"
      indicator-dots="{{true}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#fff"
      autoplay="{{false}}"
    >
      <swiper-item wx:for="{{product.images}}" wx:key="*this">
        <image class="cover-img" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <image
      wx:elif="{{product.image}}"
      class="cover-img"
      src="{{product.image}}"
      mode="aspectFill"
    />
    <view wx:else class="cover-img cover-placeholder">暂无图片</view>
  </view>
  <view class="card info-card">
    <view class="row">
      <text class="label">商品名称</text>
      <text class="value name">{{product.name}}</text>
    </view>
    <block wx:if="{{product.supplierList && product.supplierList.length > 0}}">
      <view class="row" wx:if="{{product.supplierList.length === 1}}">
        <text class="label">供应商</text>
        <text class="value">{{product.supplierList[0].supplierName || '—'}}</text>
      </view>
      <view class="spec-section" wx:if="{{product.supplierList.length > 1}}">
        <text class="spec-section-title">选择供应商</text>
        <view class="spec-chips">
          <view
            class="spec-chip {{selectedSupplierIndex === index ? 'active' : ''}}"
            wx:for="{{product.supplierList}}"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onSelectSupplier"
          >{{item.supplierName || '供应商' + (index + 1)}}</view>
        </view>
      </view>
      <view class="spec-section">
        <text class="spec-section-title">选择规格</text>
        <view class="spec-chips" wx:if="{{currentSkuList.length > 0}}">
          <view
            class="spec-chip {{selectedSkuIndex === index ? 'active' : ''}}"
            wx:for="{{currentSkuList}}"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onSelectSku"
          >{{item.specName || '规格' + (index + 1)}}</view>
        </view>
        <view class="spec-price-panel" wx:if="{{currentSkuList.length > 0 && currentSkuList[selectedSkuIndex]}}">
          <view class="spec-price-row">
            <text class="spec-price-label">来货价</text>
            <text class="spec-price-value cost">¥{{currentSkuList[selectedSkuIndex].costPrice || '—'}}</text>
          </view>
          <view class="spec-price-row">
            <text class="spec-price-label">售价</text>
            <text class="spec-price-value sale">¥{{currentSkuList[selectedSkuIndex].salePrice || '—'}}</text>
          </view>
        </view>
      </view>
    </block>
    <block wx:elif="{{product.skuList && product.skuList.length > 0}}">
      <view class="row" wx:if="{{product.supplier}}">
        <text class="label">供应商</text>
        <text class="value">{{product.supplier}}</text>
      </view>
      <view class="spec-section">
        <text class="spec-section-title">选择规格</text>
        <view class="spec-chips">
          <view
            class="spec-chip {{selectedSkuIndex === index ? 'active' : ''}}"
            wx:for="{{product.skuList}}"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onSelectSku"
          >{{item.specName || '规格' + (index + 1)}}</view>
        </view>
        <view class="spec-price-panel">
          <view class="spec-price-row">
            <text class="spec-price-label">来货价</text>
            <text class="spec-price-value cost">¥{{product.skuList[selectedSkuIndex].costPrice || '—'}}</text>
          </view>
          <view class="spec-price-row">
            <text class="spec-price-label">售价</text>
            <text class="spec-price-value sale">¥{{product.skuList[selectedSkuIndex].salePrice || '—'}}</text>
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="row" wx:if="{{product.supplier}}">
        <text class="label">供应商</text>
        <text class="value">{{product.supplier}}</text>
      </view>
      <view class="row" wx:if="{{product.spec}}">
        <text class="label">规格</text>
        <text class="value">{{product.spec}}</text>
      </view>
      <view class="row">
        <text class="label">来货价</text>
        <text class="value cost">¥{{product.costPrice || '—'}}</text>
      </view>
      <view class="row">
        <text class="label">售价</text>
        <text class="value sale">¥{{product.salePrice || '—'}}</text>
      </view>
    </block>
  </view>
  <view class="footer">
    <button class="edit-btn" type="primary" bindtap="onEdit">编辑</button>
    <button
      class="delete-btn"
      type="warn"
      bindtap="onDelete"
      loading="{{deleting}}"
    >
      删除商品
    </button>
  </view>
</view>
<view class="empty" wx:else>商品不存在或已下架</view>
