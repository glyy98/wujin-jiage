/* product-detail/index.wxss - 商品详情 */
page {
  background-color: #f5f5f5;
}

.container {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx 40rpx;
  font-family: PingFang SC, sans-serif;
}

.cover-wrap {
  width: 100%;
  height: 420rpx;
  background: #e8e8e8;
}

.cover-swiper {
  width: 100%;
  height: 100%;
}

.cover-swiper .cover-img {
  width: 100%;
  height: 100%;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.info-card {
  width: 100%;
  box-sizing: border-box;
  margin: 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.footer {
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.edit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.delete-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.row {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.row:last-child {
  border-bottom: none;
}

/* 多规格：规格块 + 点击后显示价格 */
.spec-section {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.spec-section-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.spec-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-chip {
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.spec-chip.active {
  background: #e8f2fe;
  border-color: #1a5fb4;
  color: #1a5fb4;
  font-weight: 500;
}

.spec-price-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.spec-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.spec-price-row:first-child {
  padding-top: 0;
}

.spec-price-label {
  font-size: 28rpx;
  color: #666;
}

.spec-price-value {
  font-size: 30rpx;
  font-weight: 500;
}

.spec-price-value.cost {
  color: #333;
}

.spec-price-value.sale {
  color: #e54545;
  font-weight: 600;
  font-size: 34rpx;
}

.label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #666;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.value.name {
  font-weight: 500;
  font-size: 32rpx;
}

.value.cost {
  color: #666;
}

.value.sale {
  color: #e54545;
  font-weight: 600;
  font-size: 34rpx;
}

.empty {
  padding: 120rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
