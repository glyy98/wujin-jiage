<!--goodsList/goodsList.wxml - 商品列表，从云数据库 goods 读取-->
<wxs module="sel">
function isSelected(selectedIds, id) {
  if (!selectedIds || selectedIds.length === 0 || id == null) return false;
  var s = id + '';
  for (var i = 0; i < selectedIds.length; i++) {
    if ((selectedIds[i] + '') === s) return true;
  }
  return false;
}
module.exports.isSelected = isSelected;
</wxs>
<view class="container">
  <view class="toolbar" wx:if="{{!selectMode}}">
    <view class="export-btn" bindtap="onExport" disabled="{{exporting}}">导出 Excel</view>
    <view class="btn-select" bindtap="enterSelectMode">多选</view>
  </view>
  <view class="toolbar select-toolbar" wx:if="{{selectMode}}">
    <view class="toolbar-left">
      <view class="btn-link" bindtap="onToggleSelectAll">{{selectAll ? '取消全选' : '全选'}}</view>
      <text class="selected-count" wx:if="{{selectedIds.length > 0}}">已选 {{selectedIds.length}} 项</text>
    </view>
    <view class="toolbar-right">
      <view class="btn-del-batch" bindtap="onBatchDelete" disabled="{{selectedIds.length === 0}}">删除</view>
      <view class="btn-cancel-select" bindtap="exitSelectMode">取消</view>
    </view>
  </view>
  <view class="product-list" wx:if="{{list.length > 0}}">
    <view
      class="product-item {{selectMode && sel.isSelected(selectedIds, item._id) ? 'selected' : ''}}"
      wx:for="{{list}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onItemTap"
    >
      <view class="product-item-check" wx:if="{{selectMode}}">
        <view class="check-icon {{sel.isSelected(selectedIds, item._id) ? 'checked' : ''}}">{{sel.isSelected(selectedIds, item._id) ? '✓' : ''}}</view>
      </view>
      <view class="product-cover">
        <image
          wx:if="{{item.image}}"
          class="product-img"
          src="{{item.image}}"
          mode="aspectFit"
          data-url="{{item.image}}"
          catchtap="onPreviewImage"
        />
        <view wx:else class="product-img product-img-placeholder">暂无图片</view>
      </view>
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-spec" wx:if="{{item.spec}}">规格：{{item.spec}}</view>
        <view class="product-supplier" wx:if="{{item.supplier}}">供应商：{{item.supplier}}</view>
        <view class="product-prices">
          <text class="price-label">售价</text>
          <text class="price-sale">¥{{item.salePrice || '—'}}</text>
          <text class="price-cost" wx:if="{{item.costPrice}}">来货价 ¥{{item.costPrice}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="empty" wx:elif="{{!loading}}">暂无商品</view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>
